{
  "name": "logseq-rs",
  "private": true,
  "version": "0.1.6",
  "type": "module",
  "description": "全视维 - 使用 Rust + Tauri + React + TypeScript 重构的本地优先知识图谱应用。",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "package:msi": "tauri build --bundles msi",
    "package:nsis": "tauri build --bundles nsis",
    "package:dmg": "tauri build --bundles dmg",
    "package:deb": "tauri build --bundles deb",
    "package:appimage": "tauri build --bundles appimage",
    "package:updater": "tauri build --bundles updater",
    "signer:keygen": "tauri signer generate -w ~/.tauri/logseq-rs.key",
    "icons": "tauri icon src-tauri/icons/app-source.png --output src-tauri/icons"
  },
  "dependencies": {
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.0.1",
    "@tauri-apps/plugin-fs": "^2.0.3",
    "@types/d3-force": "^3.0.10",
    "d3-force": "^3.0.0",
    "nanoid": "^5.0.9",
    "pdfjs-dist": "^4.7.76",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tldraw": "^4.5.10",
    "y-indexeddb": "^9.0.12",
    "y-websocket": "^2.0.4",
    "yjs": "^13.6.21",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.10.1",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  }
}
