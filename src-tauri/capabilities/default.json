{
  "$schema": "https://schema.tauri.app/capability/2.0.0",
  "identifier": "default",
  "description": "Default capability for the main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "updater:default"
  ]
}
