{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Quanshiwei",
  "version": "0.1.4",
  "identifier": "com.logseqrs.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "鍏ㄨ缁?,
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": ["nsis", "deb", "appimage", "dmg", "app"],
    "category": "Productivity",
    "shortDescription": "Knowledge graph notes, rebuilt in Rust + Tauri.",
    "longDescription": "鍏ㄨ缁存槸涓€娆炬湰鍦颁紭鍏堢殑鐭ヨ瘑鍥捐氨搴旂敤锛屾敮鎸?Markdown 涓?SQLite 鍚庣銆佸叏鏂囨悳绱€佺櫧鏉裤€佹棩蹇椼€佷换鍔″拰寮曠敤鍥捐氨瑙嗗浘銆?,
    "copyright": "Copyright 漏 2026 鍏ㄨ缁?contributors",
    "publisher": "鍏ㄨ缁?,
    "homepage": "https://github.com/logseq/logseq",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md"],
        "name": "Markdown Document",
        "description": "Markdown note",
        "role": "Editor"
      }
    ],
    "resources": [],
    "externalBin": [],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "allowDowngrades": true,
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "SimpChinese"],
        "displayLanguageSelector": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["quanshiwei", "lsrs"]
      },
      "mobile": [
        {
          "host": "clip.quanshiwei.app",
          "pathPrefix": ["/"]
        }
      ]
    }
  }
}
